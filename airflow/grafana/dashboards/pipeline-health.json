{
  "title": "W3C ETL — Pipeline Health",
  "uid": "w3c-pipeline-health",
  "tags": ["w3c", "etl", "pipeline", "health"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Data Freshness",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "w3c_data_freshness_seconds{source=\"azure_sql\"}",
          "legendFormat": "Last Load",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 21600 },
              { "color": "red", "value": 86400 }
            ]
          },
          "mappings": [],
          "max": 259200
        },
        "overrides": []
      },
      "description": "Seconds since last successful pipeline load. Thresholds: <6h (green), 6-24h (yellow), >24h (red)"
    },
    {
      "id": 2,
      "title": "Pipeline Status",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "w3c_pipeline_last_run_status{source=\"azure_sql\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Stale", "color": "red" },
                "1": { "text": "Healthy", "color": "green" }
              }
            }
          ],
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "description": "Pipeline operational status. 1 = data loaded within last 2 hours, 0 = stale."
    },
    {
      "id": 3,
      "title": "dbt Test Pass Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "w3c_dbt_test_pass_rate",
          "legendFormat": "Pass Rate",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "description": "Fraction of dbt tests passing (1.0 = all passing)."
    },
    {
      "id": 4,
      "title": "DAG Run Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "airflow_dag_run_duration_seconds_sum / airflow_dag_run_duration_seconds_count",
          "legendFormat": "Avg Duration",
          "refId": "A"
        },
        {
          "expr": "airflow_dag_run_duration_seconds_max",
          "legendFormat": "Max Duration",
          "refId": "B"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "description": "Average and max DAG run duration over time."
    },
    {
      "id": 5,
      "title": "Duration Percentiles",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(airflow_dag_run_duration_seconds_bucket[1h])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(airflow_dag_run_duration_seconds_bucket[1h])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(airflow_dag_run_duration_seconds_bucket[1h])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "description": "p50, p95, and p99 DAG run duration percentiles over the last hour."
    },
    {
      "id": 6,
      "title": "Task Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(airflow_ti_finish{state=\"success\"}[5m]))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        },
        "overrides": []
      },
      "description": "Rate of successful task completions per second."
    },
    {
      "id": 7,
      "title": "Task Failure Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(airflow_ti_finish{state=\"failed\"}[5m]))",
          "legendFormat": "Failure Rate",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        },
        "overrides": []
      },
      "description": "Rate of failed task completions per second."
    },
    {
      "id": 8,
      "title": "Row Count — Bronze",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "w3c_row_count{source=\"bronze\"}",
          "legendFormat": "Bronze",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "green", "value": 100000 }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "description": "Row count in bronze_raw_logs (Unity Catalog via Databricks REST API)."
    },
    {
      "id": 9,
      "title": "Row Count — Silver",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [
        {
          "expr": "w3c_row_count{source=\"silver\"}",
          "legendFormat": "Silver",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "green", "value": 100000 }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "description": "Row count in silver_enriched_logs (Unity Catalog via Databricks REST API)."
    },
    {
      "id": 10,
      "title": "Row Count — Azure SQL",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        {
          "expr": "w3c_row_count{source=\"azure_sql\"}",
          "legendFormat": "Azure SQL",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "green", "value": 100000 }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "description": "Row count in dbo.raw_enriched (Azure SQL via pymssql)."
    }
  ]
}
