AIRFLOW_UID=50000

# ── W3C Warehouse Database Connection Setup ──
# To connect to AWS RDS, uncomment the variables below and add your database details.
# If these remain commented out, Airflow will fall back to the local Docker PostgreSQL database.

#W3C_USE_RDS=true
#W3C_DB_HOST=your-rds-endpoint.eu-west-2.rds.amazonaws.com
#W3C_DB_PORT=5432
#W3C_DB_NAME=postgres
#W3C_DB_USER=postgres
#W3C_DB_PASS=your-password

# ── Monitoring Stack (Grafana) ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS=false

# ── Monitoring Stack (cAdvisor Docker Socket) ──
# Path to the Docker socket. Set this on macOS where the default
# /var/run/docker.sock does not exist. Example:
# DOCKER_SOCKET_PATH=$HOME/.docker/run/docker.sock
# DOCKER_SOCKET_PATH=/var/run/docker.sock
