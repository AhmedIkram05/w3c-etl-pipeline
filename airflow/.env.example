AIRFLOW_UID=50000

# ── Slack Alert Notifications ──
# Incoming webhook URL for Alertmanager to send alerts to Slack.
# Get yours at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/T00/xxxx

# ── Monitoring Stack (Grafana) ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS=false

# ── Monitoring Stack (cAdvisor Docker Socket) ──
# Path to the Docker socket. Set this on macOS where the default
# /var/run/docker.sock does not exist. Example:
DOCKER_SOCKET_PATH=$HOME/.docker/run/docker.sock
DOCKER_SOCKET_PATH=/var/run/docker.sock

# ── Spark Cluster Connection ──
# Used by Airflow's SparkSubmitOperator to submit jobs to the Spark master.
# The default value points to the local Docker Spark master container.
SPARK_MASTER_URL=spark://spark-master:7077

# ── Dataset URIs (Data Contracts) ──
# Dataset produced by spark_ingestion, consumed by dbt_marts
DATASET_WAREHOUSE_LOADED=postgres://postgres:5432/w3c_warehouse/public/raw_enriched_loaded

# ── Azure SQL (dimension export in spark_ingestion_azure DAG) ──
AZURE_SQL_SERVER=sql-w3c-etl.database.windows.net
AZURE_SQL_DATABASE=w3c-etl-db
AZURE_SQL_USER=sqladmin
AZURE_SQL_PASS=W3clrzaKiTTsFVNa6LZ!

# ── Azure Blob Storage (dbt docs sync from Databricks to Airflow) ──
# These match the Databricks secret scope naming (AZURE_STORAGE_*).
# Used by export_dbt_docs_azure to download docs from gold/dbt-docs/.
#AZURE_STORAGE_ACCOUNT=stw3cetlwestus3
#AZURE_STORAGE_KEY=your-storage-key

# ── Databricks Workflow job ID (from terraform/part_b output.workflow_job_id) ──
DATABRICKS_JOB_ID=847995192336508

# ── Databricks Host and PAT Token (for data freshness probe & API access) ──
# Used by the data-freshness-probe sidecar for Unity Catalog REST API calls.
# Format: adb-<workspace-id>.<databricks-region>.azuredatabricks.net
DATABRICKS_HOST=adb-123456.10.azuredatabricks.net
DATABRICKS_PAT_TOKEN=your-databricks-pat-token

# ── Databricks SQL Warehouse ID (for row-count queries via SQL Statements API) ──
# Find this in Databricks -> SQL Warehouses -> Serverless Starter Warehouse -> ID
DATABRICKS_WAREHOUSE_ID=your-warehouse-id

# ── Additional PIP packages to install at container startup ──
_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-databricks==4.6.0

# ── MaxMind GeoLite2 License Key (REQUIRED) ──
# Used by the geoip-downloader init service to fetch GeoLite2-City.mmdb and
# GeoLite2-ASN.mmdb at startup. Sign up for a free key at:
#   https://www.maxmind.com/en/geolite2/signup
# The pipeline will fail to start without this variable.
MAXMIND_LICENSE_KEY=your-license-key-here
