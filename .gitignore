# Secrets — never commit
.env
.env.azure
.vscode

# macOS junk
.DS_Store

# Python bytecode
dags/w3c/__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Airflow runtime files — these are generated, not source
logs/
airflow.db
airflow.cfg
airflow-webserver.pid
standalone_admin_password.txt

# dbt docs source files (copied from target/ then synced to docs/dbt/ for GH Pages)
# GH Pages served from: airflow/data/dbt-docs/ → docs/dbt/

# MaxMind GeoLite2 databases — too large, download manually per Phase 0
/data/geoip/
copilot-instructions.md
.agents

# dbt — build artifacts
airflow/dbt/w3c/target/
airflow/dbt/w3c/dbt_packages/

# Prometheus — runtime data (config is version-controlled separately)
prometheus/data/

# Grafana — runtime data (provisioning config is version-controlled)
grafana/data/
AGENTS.md

# Spark Delta Lake data (generated at runtime)
airflow/spark/delta/*
!airflow/spark/delta/.gitkeep

# Terraform — provider binaries per environment
**/.terraform/

# Terraform state files — never commit
*.tfstate
*.tfstate.*

# Pre-commit
.pre-commit-cache/

utils.zip
